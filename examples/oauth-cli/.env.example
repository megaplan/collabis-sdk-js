# Optional: reuse a registered client id. If unset, the script dynamically
# registers a public client (DCR) and prints the new client_id.
# COLLABIS_CLIENT_ID=

# Optional: target stage instead of prod
# COLLABIS_ISSUER=https://collabis.ru
# COLLABIS_RESOURCE=https://api.collabis.ru

# Loopback port for the OAuth redirect (must match the registered redirect_uri)
# OAUTH_PORT=8765
